# Backend Environment Variables
# Copy this file to .env and fill in your values

# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# --- AWS Config (defaults shown) ---
AWS_PRICING_REGION=us-east-1
AWS_RETRY_MAX_ATTEMPTS=3
AWS_CONNECT_TIMEOUT_SECONDS=2
AWS_READ_TIMEOUT_SECONDS=5
AWS_SPOT_HISTORY_HOURS=6
AWS_MAX_PRICE_PAGES=5

# --- App Config ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
DEFAULT_COMPARE_CANDIDATE_REGIONS=us-east-1,us-west-2,eu-west-1

# --- Firebase (optional, only needed for auth) ---
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=path/to/firebase-adminsdk.json
